{
  "name": "passport-kakao-login",
  "version": "0.1.0",
  "description": "Kakao OAuth2 authentication strategy for Passport",
  "license": "MIT",
  "author": "jhpung",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jhpung/passport-kakao-login.git"
  },
  "keywords": [
    "passport",
    "kakao",
    "kakaotalk",
    "oauth2",
    "authentication"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && rollup -c && rimraf dist/types",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "passport-oauth2": "^1.8.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^26.1.0",
    "@types/passport-oauth2": "^1.8.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
