{
  "name": "passport-kakao-login",
  "version": "1.1.0",
  "description": "Kakao OAuth2 authentication strategy for Passport",
  "license": "MIT",
  "author": "jhpung",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jhpung/passport-kakao-login.git"
  },
  "keywords": [
    "passport",
    "kakao",
    "kakaotalk",
    "oauth2",
    "authentication"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "rimraf dist && rollup -c && rimraf dist/types",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "passport-oauth2": "^1.8.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@vitest/coverage-v8": "^4.1.9",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^26.1.0",
    "@types/passport-oauth2": "^1.8.0",
    "eslint": "^10.6.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
